        const demoData = [
            ['', 'الفرز الأول', '10', '5', 'أحمد، فاطمة، عمر'],
            ['', 'الفرز الثاني', '8', '7', 'سارة، خالد، محمد'],
            ['', 'الفرز الثالث', '12', '3', 'علي، حسن، نور'],
        ];
        
        const tbody = document.getElementById('shiftsBody');
        tbody.innerHTML = '';
        
        demoData.forEach(row => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td><strong>${row[1]}</strong></td>
                <td>${row[2]}</td>
                <td>${row[3]}</td>
                <td>${row[4]}</td>
            `;
            tbody.appendChild(tr);
        });
        
        document.getElementById('shiftMonthName').textContent = this.currentMonthName;
    }

    loadDemoOncall() {
        const demoHeaders = ['اليوم', 'التاريخ', 'الطبيب المناوب', 'الطبيب الاحتياط'];
        const demoData = [
            ['السبت', '2024-07-01', 'أحمد محمد', 'فاطمة خالد'],
